# ──────────────────────────────────────────────────────────────────────────────
# Copia este archivo como backend/.env y rellena los valores antes de iniciar
# el servidor. El archivo .env real está en .gitignore y nunca debe subirse
# al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=

# Bot de Telegram
# Obtén el token creando un bot con @BotFather en Telegram.
# Este valor es OBLIGATORIO: el servidor no arrancará si no está definido,
# ya que el bot se inicializa en el lifespan de FastAPI.
TELEGRAM_BOT_TOKEN=
